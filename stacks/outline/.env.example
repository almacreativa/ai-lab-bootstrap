# Copiar a .env y completar. NUNCA commitear .env a git.

NODE_ENV=production

# [HUMANO] Generar cada uno con: openssl rand -hex 32
SECRET_KEY=REEMPLAZAR
UTILS_SECRET=REEMPLAZAR

# Password del Postgres de Outline. Generar con: openssl rand -hex 16
OUTLINE_DB_PASSWORD=REEMPLAZAR
DATABASE_URL=postgres://outline:REEMPLAZAR_MISMO_PASSWORD@outline-postgres:5432/outline
PGSSLMODE=disable
REDIS_URL=redis://outline-redis:6379

# [HUMANO] URL pública: la URL HTTPS de Tailscale (ver README, paso 2)
# Ejemplo: https://<HOSTNAME>.<TAILSCALE_DOMAIN>
URL=https://REEMPLAZAR.ts.net

# Detrás de tailscale serve (que ya termina TLS)
FORCE_HTTPS=false

# Storage local — sin MinIO/S3
FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FILE_STORAGE_UPLOAD_MAX_SIZE=26214400

# [HUMANO] Google OAuth (ver README, paso 3)
GOOGLE_CLIENT_ID=REEMPLAZAR.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REEMPLAZAR

DEFAULT_LANGUAGE=es_ES
WEB_CONCURRENCY=1
