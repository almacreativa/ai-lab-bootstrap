# Copiar a .env y completar. NUNCA commitear .env a git.

# ── LLM de extracción de hechos ──────────────────────────────────────────────
# Provider del lab (API OpenAI-compatible). Elegir UNA opción:
#
# Opción A — OpenCode Zen (gratis, default del lab):
#   OPENAI_BASE_URL=https://opencode.ai/zen/v1
#   LLM_MODEL=opencode/deepseek-v4-flash-free
#   OPENAI_API_KEY= la key de opencode-zen (la misma del credential_pool de Hermes)
#
# Opción B — OpenCode Go (pago, mejor calidad de extracción):
#   OPENAI_BASE_URL=https://opencode.ai/zen/v1
#   LLM_MODEL=deepseek-v4-flash
#   OPENAI_API_KEY= la key de opencode-go
#
# Opción C — Ollama Cloud (alternativa):
#   OPENAI_BASE_URL=https://ollama.com/v1
#   LLM_MODEL=qwen3-coder-next
#   OPENAI_API_KEY= la key de ollama-cloud

OPENAI_API_KEY=REEMPLAZAR
OPENAI_BASE_URL=https://opencode.ai/zen/v1
LLM_MODEL=opencode/deepseek-v4-flash-free

# ── Embeddings locales (Ollama del compose — no tocar salvo cambio de modelo) ─
EMBED_MODEL=nomic-embed-text
EMBED_DIMS=768

# ── Auth del wrapper ─────────────────────────────────────────────────────────
# Si se setea, todo request necesita header X-API-Key con este valor.
# Generar con: openssl rand -hex 24
MEM0_API_KEY=
