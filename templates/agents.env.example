# ~/.env_agents — API keys para agentes del lab
# Usado como env_file en docker-compose de cada agente.
# Copiar a ~/.env_agents y completar. Permisos: chmod 600 ~/.env_agents

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Búsqueda web self-hosted (SearXNG levantado por el bootstrap en localhost:8080)
# Hermes lo usa automáticamente cuando esta variable está presente
SEARXNG_URL=http://localhost:8080

WORKSPACE_DIR=/app/workspace
LOG_LEVEL=INFO
LLM_TIMEOUT=120
