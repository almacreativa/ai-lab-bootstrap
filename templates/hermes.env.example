# ~/.hermes/.env — secrets de Hermes Agent
# Copiar a ~/.hermes/.env y completar. Permisos: chmod 600 ~/.hermes/.env

# OpenCode providers — obtener en https://opencode.ai → Settings → API Keys
# opencode-go: suscripción mensual — provider principal de alto volumen
OPENCODE_GO_API_KEY=
# opencode zen: tier gratuito — usado como fallback y para tareas auxiliares
OPENCODE_ZEN_API_KEY=

# ollama-cloud: tier gratuito, modelos grandes (minimax-m3, deepseek-v4-pro, kimi-k2.6, etc.)
# Extraer desde ~/.local/share/opencode/auth.json (key del provider "ollama-cloud")
OLLAMA_API_KEY=

# Telegram bot token — crear bot con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=

# chat_id numérico del usuario autorizado
# Obtener enviando /start a @userinfobot en Telegram
TELEGRAM_ALLOWED_USERS=

TERMINAL_TIMEOUT=120
TERMINAL_LIFETIME_SECONDS=300
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false
