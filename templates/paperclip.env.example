# ~/ai-lab/repos/paperclip/.env.paperclip — config de Paperclip
# Copiar a la ruta indicada y completar. Permisos: chmod 600

# Generar con: openssl rand -hex 32
BETTER_AUTH_SECRET=

# URL pública del servidor, ej: http://100.x.x.x:3100
PAPERCLIP_PUBLIC_URL=

PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# UID/GID del usuario del sistema (1000 por defecto en Ubuntu)
USER_UID=1000
USER_GID=1000

PAPERCLIP_TELEMETRY_DISABLED=1
OPENCODE_ALLOW_ALL_MODELS=true
